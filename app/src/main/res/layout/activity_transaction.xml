<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← "
            android:textSize="18sp"
            android:textColor="@color/text_white"
            android:clickable="true"
            android:focusable="true"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fine Calculator"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overdue Book Transaction"
                android:textSize="10sp"
                android:textColor="#b0bcd8"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Formula info box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_formula"
                android:orientation="vertical"
                android:layout_margin="12dp"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fine Formula"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fine = Days Overdue × OMR 0.100"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Form fields -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="14dp"
                android:paddingRight="14dp">

                <TextView style="@style/FieldLabel" android:text="Member Name *"/>
                <EditText
                    android:id="@+id/etMemberName"
                    style="@style/LibraryInput"
                    android:hint="@string/hint_member_name"
                    android:inputType="textCapWords"
                    android:maxLines="1"/>

                <TextView style="@style/FieldLabel" android:text="Book Title"/>
                <EditText
                    android:id="@+id/etBookTitle"
                    style="@style/LibraryInput"
                    android:hint="@string/hint_book_title"
                    android:inputType="textCapWords"
                    android:maxLines="1"/>

                <TextView style="@style/FieldLabel" android:text="Due Date"/>
                <EditText
                    android:id="@+id/etDueDate"
                    style="@style/LibraryInput"
                    android:hint="@string/hint_due_date"
                    android:inputType="text"
                    android:maxLines="1"/>

                <TextView style="@style/FieldLabel" android:text="Days Overdue *"/>
                <EditText
                    android:id="@+id/etDays"
                    style="@style/LibraryInput"
                    android:hint="@string/hint_days_overdue"
                    android:inputType="number"
                    android:maxLines="1"/>

            </LinearLayout>

            <!-- Result box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_result"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_margin="14dp"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CALCULATED FINE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/success"/>

                <TextView
                    android:id="@+id/tvFineResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OMR 0.000"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1b5e20"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvFineFormula"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="10sp"
                    android:textColor="@color/success"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:weightSum="3">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalculate"
                    style="@style/BtnPrimary"
                    android:text="Calculate"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    style="@style/BtnGrey"
                    android:text="Reset"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClose"
                    style="@style/BtnOutline"
                    android:text="Close"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom nav bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <LinearLayout android:id="@+id/navHome"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="9sp" android:textColor="#8090b8"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navBooks"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📚" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Books" android:textSize="9sp" android:textColor="#8090b8"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navFines"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💰" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Fines" android:textSize="9sp" android:textColor="@color/text_white"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navReport"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📋" android:textSize="18sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Report" android:textSize="9sp" android:textColor="#8090b8"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
